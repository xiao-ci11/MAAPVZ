            "name": "签到",
            "entry": "签到_前置检查",
            "description": "进行每日签到任务"
        },
        {
            "name": "执行每日50钻(免广告卡)",
            "entry": "每日50钻_拥有免广告卡_前置检查",
            "description": "进行领取50钻石任务，前提是拥有免广告卡"
        },
        {
            "name": "植物探险",
            "entry": "植物探险_前置检查",
            "option": [
                "海盗/埃及",
                "西部/功夫",
                "未来/黑暗",
                "海滩/冰河",
                "天空/失落",
